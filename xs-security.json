{
  "xsappname": "risk-management",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.RiskViewer",
      "description": "Risk Viewer"
    },
    {
      "name": "$XSAPPNAME.RiskManager",
      "description": "Risk Manager"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "RiskViewer",
      "description":"Risk Viewer",
